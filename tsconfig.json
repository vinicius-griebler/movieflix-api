{
  "compilerOptions": {
    // ADICIONADO AQUI ✅
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // File Layout
    // "rootDir": "./src",
    // "outDir": "./dist",

    // Environment Settings
    "module": "CommonJS",
    "target": "es2019",
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,

    // ⚠️ esse pode causar erro com express default import
    // se continuar dando erro, comenta ele
    // "verbatimModuleSyntax": true,

    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}